# ============================================================
# Production Environment Variables — Electricity Theft System
# Copy this file to .env.local and fill in the values.
# NEVER commit the filled-in file to version control.
# ============================================================

# ----------------------------------------------------------
# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Vercel Postgres sets this automatically when you link a DB.
# ----------------------------------------------------------
DATABASE_URL=postgresql://[user]:[password]@[host]:[port]/[database]

# ----------------------------------------------------------
# JWT Authentication
# Use a strong random string — 32 characters minimum.
# Generate one with: openssl rand -base64 32
# ----------------------------------------------------------
JWT_SECRET=[strong-secret-key-32-chars-minimum]

# ----------------------------------------------------------
# Email / SMTP (Gmail example)
# Requires a Gmail App Password (not your account password).
# Enable 2FA on your Google account, then create an App Password.
# ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[your-email@gmail.com]
SMTP_PASSWORD=[app-specific-password]
SMTP_FROM=PSPCL Theft Detection <noreply@pspcl.gov.in>

# ----------------------------------------------------------
# Twilio — WhatsApp / SMS notifications (optional)
# Leave blank to disable WhatsApp/SMS alerts.
# ----------------------------------------------------------
TWILIO_ACCOUNT_SID=[optional]
TWILIO_AUTH_TOKEN=[optional]
TWILIO_WHATSAPP_FROM=[optional, e.g. whatsapp:+14155238886]
TWILIO_PHONE_FROM=[optional, e.g. +1234567890]

# ----------------------------------------------------------
# Next.js public URL
# Set to your Vercel deployment URL after first deploy.
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=https://[your-domain].vercel.app

# ----------------------------------------------------------
# Node environment
# ----------------------------------------------------------
NODE_ENV=production
